{
  "expo": {
    "name": "Sybeat",
    "slug": "sybeat",
    "version": "1.0.0",
    "scheme": "sybeat",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "bundleIdentifier": "com.sybeat_k7m2.runable",
      "supportsTablet": true
    },
    "android": {
      "package": "com.sybeat_k7m2.runable",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.0",
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "expo-router",
      "expo-av",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Sybeat to save track share cards to your gallery.",
          "savePhotosPermission": "Allow Sybeat to save images to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-audio",
      "expo-web-browser"
    ],
    "extra": {
      "apiUrl": "https://templateserver-production.up.railway.app",
      "router": {},
      "eas": {
        "projectId": "07005c4d-0810-4f12-ad77-13b9c7820197"
      }
    }
  }
}
